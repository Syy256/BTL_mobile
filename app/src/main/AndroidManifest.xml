<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WatchStore">

        <activity android:name=".activity.SplashActivity"
            android:exported="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activity.LoginActivity" android:exported="false"/>
        <activity android:name=".activity.RegisterActivity" android:exported="false"/>
        <activity android:name=".activity.MainActivity" android:exported="false"/>
        <activity android:name=".activity.ProductDetailActivity" android:exported="false"/>
        <activity android:name=".activity.CartActivity" android:exported="false"/>
        <activity android:name=".activity.OrderHistoryActivity" android:exported="false"/>
        <activity android:name=".activity.OrderDetailActivity" android:exported="false"/>
        <activity android:name=".activity.ProfileActivity" android:exported="false"/>

        <!-- Admin Activities -->
        <activity android:name=".activity.AdminDashboardActivity" android:exported="false"/>
        <activity android:name=".activity.AdminProductActivity" android:exported="false"/>
        <activity android:name=".activity.AdminProductFormActivity" android:exported="false"/>
        <activity android:name=".activity.AdminBrandActivity" android:exported="false"/>
        <activity android:name=".activity.AdminBrandFormActivity" android:exported="false"/>
        <activity android:name=".activity.AdminOrderActivity" android:exported="false"/>
        <activity android:name=".activity.AdminUserActivity" android:exported="false"/>

    </application>
</manifest>
